AGENT_REPORT_INTERVAL=30s
AGENT_HEALTHCHECK_URLS=http://localhost:8000/healthz
AGENT_EVIDENCE_SOURCES_JSON=[]
API_INTERNAL_URL=http://api:8000
ALERT_PENDING_OBSERVATIONS=2
