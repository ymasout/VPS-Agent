CONTROL_PLANE_DOMAIN=ops.example.com
CADDY_ADMIN_USER=admin
# 使用 `docker run --rm caddy:2-alpine caddy hash-password --plaintext '你的密码'` 生成。
# bcrypt 哈希中的 $ 必须写成 $$，否则 Docker Compose 会把它当成变量。
CADDY_ADMIN_PASSWORD_HASH=$$2a$$14$$replace_with_caddy_hash

POSTGRES_DB=vps_agent
POSTGRES_USER=vps_agent
POSTGRES_PASSWORD=replace_with_openssl_rand_hex_32
ADMIN_API_TOKEN=replace_with_openssl_rand_hex_32

LOG_LEVEL=INFO
AGENT_OFFLINE_AFTER_SECONDS=90
AGENT_AVAILABILITY_SCAN_INTERVAL_SECONDS=30
OPERATION_SIGNING_KEY_ID=
# Ed25519 32 字节私钥原始值的 Base64；不得提交真实值。
OPERATION_SIGNING_PRIVATE_KEY_BASE64=
OPERATION_OBSERVATION_MAX_AGE_SECONDS=120
OPERATION_CLAIM_LEASE_SECONDS=60
OPERATION_EXECUTION_TIMEOUT_SECONDS=30
OPERATION_EXECUTION_RESULT_GRACE_SECONDS=15
OPERATION_VERIFICATION_WINDOW_SECONDS=30
OPERATION_VERIFICATION_TIMEOUT_SECONDS=180
OPERATION_MAX_OUTPUT_BYTES=16384
OPERATION_MAX_OUTPUT_LINES=100
# 对应公钥可以进入安装命令；私钥只能留在控制平面。
AGENT_OPERATION_KEY_ID=
AGENT_OPERATION_PUBLIC_KEY_BASE64=
ALERT_PENDING_OBSERVATIONS=2
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
NOTIFICATION_TIMEOUT_SECONDS=5
NOTIFICATION_SENDING_STALE_SECONDS=120
DIAGNOSTIC_PROVIDER=deterministic
DIAGNOSTIC_API_URL=
DIAGNOSTIC_API_KEY=
DIAGNOSTIC_MODEL=ops-diagnostic
DIAGNOSTIC_TIMEOUT_SECONDS=30
DIAGNOSTIC_LOG_LOOKBACK_SECONDS=900
DIAGNOSTIC_MAX_LOG_LINES=200
DIAGNOSTIC_MAX_LOG_BYTES=65536
DIAGNOSTIC_COLLECTION_TIMEOUT_SECONDS=10
DIAGNOSTIC_REQUEST_CLAIM_SECONDS=60
DIAGNOSTIC_RUN_STALE_SECONDS=300
GITHUB_APP_ID=
# GitHub App PEM 私钥的 Base64，不要提交真实值。
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=
GITHUB_API_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_ALLOWED_FILE_PATHS=README.md,docker-compose.yml,compose.yaml
GITHUB_MAX_FILE_BYTES=65536
GITHUB_WEBHOOK_MAX_BYTES=1048576
GITHUB_SYNC_CONCURRENCY=4
GITHUB_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
