CONTROL_PLANE_DOMAIN=ops.example.com
CADDY_ADMIN_USER=admin
# 使用 `docker run --rm caddy:2-alpine caddy hash-password --plaintext '你的密码'` 生成。
# bcrypt 哈希中的 $ 必须写成 $$，否则 Docker Compose 会把它当成变量。
CADDY_ADMIN_PASSWORD_HASH=$$2a$$14$$replace_with_caddy_hash

POSTGRES_DB=vps_agent
POSTGRES_USER=vps_agent
POSTGRES_PASSWORD=replace_with_openssl_rand_hex_32
ADMIN_API_TOKEN=replace_with_openssl_rand_hex_32

LOG_LEVEL=INFO
AGENT_OFFLINE_AFTER_SECONDS=90
ALERT_PENDING_OBSERVATIONS=2
DINGTALK_WEBHOOK_URL=
DINGTALK_SECRET=
NOTIFICATION_TIMEOUT_SECONDS=5
NOTIFICATION_SENDING_STALE_SECONDS=120
